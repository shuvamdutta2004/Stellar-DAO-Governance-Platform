# ─── Stellar Network ──────────────────────────────────────────────────────────
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# ─── Treasury Contract ────────────────────────────────────────────────────────
# Replace with your deployed contract ID after running: npm run deploy:contract
NEXT_PUBLIC_TREASURY_CONTRACT_ID=CONTRACT_ADDRESS_HERE

# ─── Deployer / Admin ─────────────────────────────────────────────────────────
# Stellar public key of the deployer account (auto-filled by deploy script)
NEXT_PUBLIC_DEPLOYER_ADDRESS=DEPLOYER_ADDRESS_HERE

# ─── Event Polling ────────────────────────────────────────────────────────────
# Interval in milliseconds for polling contract events (default: 5000)
NEXT_PUBLIC_EVENT_POLL_INTERVAL=5000

# ─── Optional: Native Token (XLM SAC) ────────────────────────────────────────
# Stellar Asset Contract address for XLM on testnet
NEXT_PUBLIC_NATIVE_TOKEN_ADDRESS=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
